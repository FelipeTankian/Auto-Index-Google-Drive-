function createCompleteIndex() {
  // 1. Substitua o texto abaixo pelo ID da sua pasta raiz
  var rootFolderId = 'COLE_O_ID_DA_SUA_PASTA_AQUI'; 
  
  var rootFolder = DriveApp.getFolderById(rootFolderId);
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  
  // Limpa a planilha atual e cria os cabeçalhos
  sheet.clear();
  sheet.appendRow(["File Name", "Folder Path", "Access Link"]);
  sheet.getRange("A1:C1").setFontWeight("bold");
  sheet.setFrozenRows(1);
  
  var initialPath = rootFolder.getName();
  
  // Cria uma "caixa vazia" (array) na memória para guardar os dados temporariamente
  var allData = []; 
  
  // Vasculha as pastas e vai enchendo a "caixa vazia" com os dados
  listFilesInFolder(rootFolder, initialPath, allData);
  
  // Quando terminar de vasculhar tudo, descarrega a "caixa" toda de uma vez na planilha
  if (allData.length > 0) {
    sheet.getRange(2, 1, allData.length, 3).setValues(allData);
  }
}

function listFilesInFolder(folder, path, allData) {
  var files = folder.getFiles();
  while (files.hasNext()) {
    var file = files.next();
    // Em vez de escrever na planilha, guarda na memória (allData)
    allData.push([file.getName(), path, file.getUrl()]); 
  }
  
  var subfolders = folder.getFolders();
  while (subfolders.hasNext()) {
    var subfolder = subfolders.next();
    var newPath = path + " > " + subfolder.getName();
    listFilesInFolder(subfolder, newPath, allData);
  }
}
